39357>>>        WebSet pbRender of oCancelChangesBtn to False
39358>>>        WebSet pbRender of oDeleteBtn to False
39359>>>        WebSet pbRender of oNewDetail to False
39360>>>        WebSet pbVisible of oBtnJugadorPosicion to False
39361>>>
39361>>>        If (NavigateData.bReadOnly) Begin
