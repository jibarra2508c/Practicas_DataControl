38641>>>        WebSet pbRender of oNewButton to True
38642>>>        WebSet pbRender of oDetailButton to True
38643>>>
38643>>>        Case Begin
38643>>>            Case (NavigateData.eNavigateType = nfFromParent)
38645>>>                // If from parent, this is a constrained drill down
38645>>>                // If Row select does main-zoom we don't need this
38645>>>                
38645>>>                Case Break
38646>>>
38646>>>            Case (NavigateData.eNavigateType = nfFromChild)
38649>>>                // If from child, this is a probably a parent lookup from a Zoom
38649>>>                Case Break
38650>>>
38650>>>            Case (NavigateData.eNavigateType = nfFromMain)
38653>>>                // If from main, this is a probably a main-file lookup from a Zoom
38653>>>                WebSet pbRender of oDetailButton to False
38654>>>                Case Break
38655>>>
38655>>>            Case Else // must be nfUndefined
38655>>>                // This may be the start of a drilldown query or this may be used for some kind of custom query.
38655>>>                // If Row select does main-zoom we don't need this               
38655>>>           
38655>>>        Case End
38655>>>
38655>>>    End_Procedure
38656>>>
38656>>>
38656>>>End_Object 
