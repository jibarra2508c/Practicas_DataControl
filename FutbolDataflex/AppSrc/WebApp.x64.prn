38459>>>    Procedure SetActionButtons
38462>>>        tWebNavigateData NavigateData
38462>>>        tWebNavigateData NavigateData
38462>>>        Boolean bHasRecord
38462>>>        Handle hoDD
38462>>>
38462>>>        Get Server to hoDD
38463>>>        Get GetNavigateData to NavigateData
38464>>>        Get HasRecord of hoDD to bHasRecord
38465>>>
38465>>>        // let's hide all buttons and then Show the ones we want
38465>>>        WebSet pbRender of oEditBtn to False
38466>>>        WebSet pbRender of oSaveBtn to False
38467>>>        WebSet pbRender of oCancelChangesBtn to False
38468>>>        WebSet pbRender of oDeleteBtn to False
38469>>>        WebSet pbRender of oNewDetail to False
38470>>>
38470>>>        If (NavigateData.bReadOnly) Begin
38472>>>            WebSet pbRender of oEditBtn to True
38473>>>        End
38473>>>>
38473>>>        Else Begin
38474>>>            WebSet pbRender of oSaveBtn to True
38475>>>            WebSet pbRender of oCancelChangesBtn to True
38476>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38477>>>            WebSet pbRender of oNewDetail to True
38478>>>        End
38478>>>>
38478>>>    End_Procedure
38479>>>
38479>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
38482>>>        // Close after save
38482>>>        Send NavigateClose Self
38483>>>    End_Procedure
38484>>>
38484>>>    // this will close the view after a delete
38484>>>    Procedure OnViewDeleted Handle hoDDO
38487>>>        Send NavigateClose Self
38488>>>    End_Procedure
38489>>>
38489>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38492>>>        Case Begin
38492>>>            Case (NavigateData.eNavigateType = nfFromMain)
38494>>>                // If from main, this is a propbably a main file Select to Zoom.
38494>>>                Case Break
38495>>>
38495>>>            Case (NavigateData.eNavigateType = nfFromParent)
38498>>>                // If from parent, this is a constrained drill down.
38498>>>                Case Break
38499>>>
38499>>>            Case (NavigateData.eNavigateType = nfFromChild)
38502>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38502>>>                Case Break
38503>>>
38503>>>            Case Else // must be nfUndefined
38503>>>
38503>>>        Case End
38503>>>
38503>>>        Send SetActionButtons
38504>>>
38504>>>    End_Procedure
38505>>>
38505>>>End_Object 
